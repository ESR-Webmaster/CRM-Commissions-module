{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@sunscape/commissions-shared": "workspace:*",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.41.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.30.4",
    "supertest": "^7.2.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
