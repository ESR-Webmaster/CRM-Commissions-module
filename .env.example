# Database
# Port 5433 avoids conflict with any local Postgres on 5432
DATABASE_URL=postgresql://commissions:commissions@localhost:5433/commissions

# API
PORT=3001
NODE_ENV=development

# Auth — shared JWT signing key with Sunscape
JWT_SECRET=change-me-in-production

# CORS — allowed origins for the admin web app
CORS_ORIGIN=http://localhost:5173

# Observability
LOG_LEVEL=info
BUILD_SHA=

# Metrics endpoint protection.
# GET /metrics requires: Authorization: Bearer <METRICS_TOKEN>
# Leave unset only in local development where /metrics is not publicly reachable.
METRICS_TOKEN=
